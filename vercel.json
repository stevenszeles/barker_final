{
  "buildCommand": "cd frontend && npm ci && npm run build && cd .. && rm -rf public && mkdir -p public && cp -R frontend/dist/* public/",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/app.py"
    },
    {
      "source": "/health",
      "destination": "/app.py"
    },
    {
      "source": "/version",
      "destination": "/app.py"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "experimentalServices": {
    "web": {
      "entrypoint": "app.py",
      "framework": "fastapi",
      "routePrefix": "/",
      "includeFiles": [
        "backend/**",
        "frontend/dist/**",
        "data/**"
      ],
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
